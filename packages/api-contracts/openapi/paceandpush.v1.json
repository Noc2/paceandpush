{
  "openapi": "3.1.0",
  "info": {
    "title": "Pace & Push API",
    "version": "2026-07-07"
  },
  "paths": {
    "/api/me": {
      "get": {
        "summary": "Current user score and settings",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Current user"
          }
        }
      }
    },
    "/api/me/settings": {
      "patch": {
        "summary": "Update current user settings",
        "responses": {
          "200": {
            "description": "Updated settings"
          },
          "400": {
            "description": "Invalid settings payload"
          },
          "401": {
            "description": "GitHub sign-in required"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AccountSettingsPatch" }
            }
          }
        }
      }
    },
    "/api/me/github/refresh": {
      "post": {
        "summary": "Refresh current user's GitHub contribution data",
        "responses": {
          "200": {
            "description": "GitHub contribution data refreshed"
          },
          "401": {
            "description": "GitHub sign-in required"
          },
          "409": {
            "description": "GitHub reconnect required or refresh failed"
          }
        }
      }
    },
    "/api/me/github/disconnect": {
      "delete": {
        "summary": "Disconnect current user's stored GitHub refresh credential",
        "responses": {
          "200": {
            "description": "GitHub refresh credential disconnected"
          },
          "401": {
            "description": "GitHub sign-in required"
          }
        }
      }
    },
    "/api/me/privacy-export": {
      "get": {
        "summary": "Export current user's stored account data",
        "responses": {
          "200": {
            "description": "Stored account data"
          },
          "401": {
            "description": "GitHub sign-in required"
          }
        }
      }
    },
    "/api/me/delete": {
      "delete": {
        "summary": "Delete current user's stored account data",
        "responses": {
          "200": {
            "description": "Deleted account"
          },
          "401": {
            "description": "GitHub sign-in required"
          }
        }
      }
    },
    "/api/leaderboard": {
      "get": {
        "summary": "Period leaderboard",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          },
          {
            "name": "board",
            "in": "query",
            "schema": { "enum": ["balanced", "commits", "distance"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Leaderboard rows"
          }
        }
      }
    },
    "/api/search/users": {
      "get": {
        "summary": "Search public leaderboard users",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string", "minLength": 2 }
          },
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching public users"
          }
        }
      }
    },
    "/api/users/{login}": {
      "get": {
        "summary": "Public user profile",
        "parameters": [
          {
            "name": "login",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Public profile"
          },
          "404": {
            "description": "Profile not found"
          }
        }
      }
    },
    "/api/mobile/pairing-codes": {
      "post": {
        "summary": "Create a short-lived mobile pairing code",
        "responses": {
          "200": {
            "description": "Pairing code"
          },
          "401": {
            "description": "GitHub sign-in required"
          }
        }
      }
    },
    "/api/mobile/auth/github/start": {
      "get": {
        "summary": "Start native mobile GitHub OAuth",
        "parameters": [
          {
            "name": "platform",
            "in": "query",
            "required": true,
            "schema": { "enum": ["ios", "android"] }
          },
          {
            "name": "label",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "callbackScheme",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "codeChallenge",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "minLength": 43, "maxLength": 128 }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to GitHub authorization"
          },
          "501": {
            "description": "GitHub OAuth not configured"
          }
        }
      }
    },
    "/api/github/oauth/callback/mobile": {
      "get": {
        "summary": "Handle native mobile GitHub OAuth callback",
        "responses": {
          "302": {
            "description": "Redirect to the native app callback URL"
          },
          "400": {
            "description": "Invalid mobile OAuth callback"
          }
        }
      }
    },
    "/api/mobile/auth/exchange": {
      "post": {
        "summary": "Exchange a native mobile auth code for a device token",
        "responses": {
          "200": {
            "description": "Device token"
          },
          "400": {
            "description": "Invalid mobile auth exchange"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MobileAuthExchangeRequest" }
            }
          }
        }
      }
    },
    "/api/mobile/me": {
      "get": {
        "summary": "Current mobile-authenticated user score and settings",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Current mobile user"
          },
          "401": {
            "description": "Invalid device token"
          }
        },
        "security": [{ "mobileBearer": [] }]
      }
    },
    "/api/mobile/me/github/disconnect": {
      "delete": {
        "summary": "Disconnect GitHub and revoke the current mobile device",
        "responses": {
          "200": {
            "description": "GitHub access and current mobile device revoked",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GitHubDisconnectResponse" }
              }
            }
          },
          "401": {
            "description": "Invalid device token"
          }
        },
        "security": [{ "mobileBearer": [] }]
      }
    },
    "/api/mobile/me/privacy-export": {
      "get": {
        "summary": "Export mobile-authenticated user's stored account data",
        "responses": {
          "200": {
            "description": "Stored account data"
          },
          "401": {
            "description": "Invalid device token"
          }
        },
        "security": [{ "mobileBearer": [] }]
      }
    },
    "/api/mobile/me/delete": {
      "delete": {
        "summary": "Delete mobile-authenticated user's stored account data",
        "responses": {
          "200": {
            "description": "Deleted account"
          },
          "401": {
            "description": "Invalid device token"
          }
        },
        "security": [{ "mobileBearer": [] }]
      }
    },
    "/api/mobile/me/settings": {
      "patch": {
        "summary": "Update mobile-authenticated user settings",
        "responses": {
          "200": {
            "description": "Updated settings"
          },
          "400": {
            "description": "Invalid settings payload"
          },
          "401": {
            "description": "Invalid device token"
          }
        },
        "security": [{ "mobileBearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AccountSettingsPatch" }
            }
          }
        }
      }
    },
    "/api/mobile/me/profile": {
      "get": {
        "summary": "Current mobile-authenticated user profile",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Private current-user profile"
          },
          "401": {
            "description": "Invalid device token"
          }
        },
        "security": [{ "mobileBearer": [] }]
      }
    },
    "/api/mobile/devices": {
      "post": {
        "summary": "Exchange a pairing code for a mobile device token",
        "responses": {
          "200": {
            "description": "Device token"
          },
          "400": {
            "description": "Invalid pairing request"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeviceExchangeRequest" }
            }
          }
        }
      }
    },
    "/api/mobile/devices/{id}/revoke": {
      "post": {
        "summary": "Revoke a mobile device token",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Revoked device"
          },
          "401": {
            "description": "GitHub sign-in required"
          },
          "404": {
            "description": "Device not found"
          }
        }
      }
    },
    "/api/mobile/distance-days": {
      "post": {
        "summary": "Upload daily running distance summaries",
        "responses": {
          "200": {
            "description": "Accepted counter"
          },
          "400": {
            "description": "Invalid distance-day payload"
          },
          "401": {
            "description": "Invalid device token"
          }
        },
        "security": [{ "mobileBearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DistanceDaysRequest" }
            }
          }
        }
      }
    },
    "/api/mobile/sync-runs": {
      "post": {
        "summary": "Record a mobile sync run",
        "responses": {
          "200": {
            "description": "Recorded sync run"
          },
          "400": {
            "description": "Invalid sync-run payload"
          },
          "401": {
            "description": "Invalid device token"
          }
        },
        "security": [{ "mobileBearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SyncRunRequest" }
            }
          }
        }
      }
    },
    "/api/jobs/recompute-scores": {
      "get": {
        "summary": "Refresh GitHub contribution summaries and recompute score snapshots",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Job report"
          },
          "401": {
            "description": "Cron secret required"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "mobileBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "PacePush device token"
      }
    },
    "schemas": {
      "AccountSettingsPatch": {
        "type": "object",
        "properties": {
          "publicLeaderboard": { "type": "boolean" },
          "units": { "enum": ["metric", "imperial"] }
        },
        "additionalProperties": false
      },
      "DeviceExchangeRequest": {
        "type": "object",
        "required": ["code", "platform", "label"],
        "properties": {
          "code": { "type": "string" },
          "platform": { "enum": ["ios", "android"] },
          "label": { "type": "string", "maxLength": 64 }
        }
      },
      "MobileAuthExchangeRequest": {
        "type": "object",
        "required": ["code", "codeVerifier"],
        "properties": {
          "code": { "type": "string" },
          "codeVerifier": { "type": "string", "minLength": 43, "maxLength": 128 }
        }
      },
      "GitHubConnectionSummary": {
        "type": "object",
        "required": ["connected", "needsReconnect", "updatedAt"],
        "properties": {
          "connected": { "type": "boolean" },
          "needsReconnect": { "type": "boolean" },
          "updatedAt": { "type": ["string", "null"], "format": "date-time" }
        }
      },
      "MobileDeviceSummary": {
        "type": "object",
        "required": ["id", "platform", "label", "lastSeenAt", "revoked"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "platform": { "enum": ["ios", "android"] },
          "label": { "type": "string" },
          "lastSeenAt": { "type": ["string", "null"], "format": "date-time" },
          "revoked": { "type": "boolean" }
        }
      },
      "GitHubDisconnectResponse": {
        "type": "object",
        "required": ["login", "github", "device", "disconnectedAt"],
        "properties": {
          "login": { "type": "string" },
          "github": { "$ref": "#/components/schemas/GitHubConnectionSummary" },
          "device": { "$ref": "#/components/schemas/MobileDeviceSummary" },
          "disconnectedAt": { "type": "string", "format": "date-time" }
        }
      },
      "DistanceDayInput": {
        "type": "object",
        "required": ["date", "meters", "sourcePlatform", "sourceHash"],
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "description": "UTC calendar day in YYYY-MM-DD format."
          },
          "meters": {
            "type": "number",
            "minimum": 0,
            "maximum": 250000,
            "description": "Running-only distance for this UTC day, in meters. Values over 100000 are accepted but flagged as implausible."
          },
          "sourcePlatform": { "enum": ["ios", "android"] },
          "sourceHash": { "type": "string", "minLength": 8 }
        }
      },
      "DistanceDaysRequest": {
        "type": "object",
        "required": ["days"],
        "properties": {
          "days": {
            "type": "array",
            "maxItems": 45,
            "items": { "$ref": "#/components/schemas/DistanceDayInput" }
          }
        }
      },
      "SyncRunRequest": {
        "type": "object",
        "required": ["platform", "status", "startedAt", "counters"],
        "properties": {
          "platform": { "enum": ["ios", "android"] },
          "status": { "enum": ["success", "warning", "error"] },
          "startedAt": { "type": "string", "format": "date-time" },
          "finishedAt": { "type": ["string", "null"], "format": "date-time" },
          "counters": {
            "type": "object",
            "additionalProperties": { "type": "number", "minimum": 0 },
            "maxProperties": 20
          },
          "errorSummary": { "type": ["string", "null"], "maxLength": 500 }
        }
      }
    }
  }
}
