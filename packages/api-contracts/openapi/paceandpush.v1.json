{
  "openapi": "3.1.0",
  "info": {
    "title": "Pace & Push API",
    "version": "2026-07-03"
  },
  "paths": {
    "/api/me": {
      "get": {
        "summary": "Current user score and settings",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Current user"
          }
        }
      }
    },
    "/api/me/settings": {
      "patch": {
        "summary": "Update current user settings",
        "responses": {
          "200": {
            "description": "Updated settings"
          },
          "401": {
            "description": "GitHub sign-in required"
          }
        }
      }
    },
    "/api/me/privacy-export": {
      "get": {
        "summary": "Export current user's stored account data",
        "responses": {
          "200": {
            "description": "Stored account data"
          },
          "401": {
            "description": "GitHub sign-in required"
          }
        }
      }
    },
    "/api/me/delete": {
      "delete": {
        "summary": "Delete current user's stored account data",
        "responses": {
          "200": {
            "description": "Deleted account"
          },
          "401": {
            "description": "GitHub sign-in required"
          }
        }
      }
    },
    "/api/leaderboard": {
      "get": {
        "summary": "Period leaderboard",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          },
          {
            "name": "board",
            "in": "query",
            "schema": { "enum": ["balanced", "commits", "distance"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Leaderboard rows"
          }
        }
      }
    },
    "/api/search/users": {
      "get": {
        "summary": "Search public leaderboard users",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string", "minLength": 2 }
          },
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching public users"
          }
        }
      }
    },
    "/api/users/{login}": {
      "get": {
        "summary": "Public user profile",
        "parameters": [
          {
            "name": "login",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Public profile"
          },
          "404": {
            "description": "Profile not found"
          }
        }
      }
    },
    "/api/mobile/pairing-codes": {
      "post": {
        "summary": "Create a short-lived mobile pairing code",
        "responses": {
          "200": {
            "description": "Pairing code"
          },
          "401": {
            "description": "GitHub sign-in required"
          }
        }
      }
    },
    "/api/mobile/auth/github/start": {
      "get": {
        "summary": "Start native mobile GitHub OAuth",
        "parameters": [
          {
            "name": "platform",
            "in": "query",
            "required": true,
            "schema": { "enum": ["ios", "android"] }
          },
          {
            "name": "label",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "callbackScheme",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to GitHub authorization"
          },
          "501": {
            "description": "GitHub OAuth not configured"
          }
        }
      }
    },
    "/api/github/oauth/callback/mobile": {
      "get": {
        "summary": "Handle native mobile GitHub OAuth callback",
        "responses": {
          "302": {
            "description": "Redirect to the native app callback URL"
          },
          "400": {
            "description": "Invalid mobile OAuth callback"
          }
        }
      }
    },
    "/api/mobile/auth/exchange": {
      "post": {
        "summary": "Exchange a native mobile auth code for a device token",
        "responses": {
          "200": {
            "description": "Device token"
          },
          "400": {
            "description": "Invalid mobile auth exchange"
          }
        }
      }
    },
    "/api/mobile/me": {
      "get": {
        "summary": "Current mobile-authenticated user score and settings",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Current mobile user"
          },
          "401": {
            "description": "Invalid device token"
          }
        }
      }
    },
    "/api/mobile/me/settings": {
      "patch": {
        "summary": "Update mobile-authenticated user settings",
        "responses": {
          "200": {
            "description": "Updated settings"
          },
          "401": {
            "description": "Invalid device token"
          }
        }
      }
    },
    "/api/mobile/me/profile": {
      "get": {
        "summary": "Current mobile-authenticated user profile",
        "responses": {
          "200": {
            "description": "Private current-user profile"
          },
          "401": {
            "description": "Invalid device token"
          }
        }
      }
    },
    "/api/mobile/devices": {
      "post": {
        "summary": "Exchange a pairing code for a mobile device token",
        "responses": {
          "200": {
            "description": "Device token"
          },
          "400": {
            "description": "Invalid pairing request"
          }
        }
      }
    },
    "/api/mobile/devices/{id}/revoke": {
      "post": {
        "summary": "Revoke a mobile device token",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Revoked device"
          },
          "401": {
            "description": "GitHub sign-in required"
          },
          "404": {
            "description": "Device not found"
          }
        }
      }
    },
    "/api/mobile/distance-days": {
      "post": {
        "summary": "Upload daily running distance summaries",
        "responses": {
          "200": {
            "description": "Accepted counter"
          }
        }
      }
    },
    "/api/mobile/sync-runs": {
      "post": {
        "summary": "Record a mobile sync run",
        "responses": {
          "200": {
            "description": "Recorded sync run"
          },
          "401": {
            "description": "Invalid device token"
          }
        }
      }
    },
    "/api/jobs/recompute-scores": {
      "get": {
        "summary": "Refresh GitHub contribution summaries and recompute score snapshots",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": { "type": "string", "pattern": "^(?:\\d{4}|\\d{4}-(?:0[1-9]|1[0-2])|\\d{4}-W(?:0[1-9]|[1-4]\\d|5[0-3]))$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Job report"
          },
          "401": {
            "description": "Cron secret required"
          }
        }
      }
    }
  }
}
